//Classe focada no que a central irá receber e o que poderá analisar

import java.util.ArrayList;
import java.util.List; 

public class Central {
    private String nomeUnidade;
    private List<Veiculo> veiculosEmEmergencia;
    
    public Central (String nomeUnidade){
        this.nomeUnidade = nomeUnidade;
        this.veiculosEmEmergencia = new ArrayList<>();
    }
        
 
    public void receberAlerta(String msg, Veiculo v) {
        
        Localizacao loc = v.getLocalizacao();
        System.out.println("Alerta recebido: " + msg + "Unidade em Emergência" + nomeUnidade);
        
        if (!veiculosEmEmergencia.contains(v)){
            veiculosEmEmergencia.add(v);
        }
        
        System.out.println("Localização do veículo: " +v.getLatitude() + "Lon" + v.getLongitude());
    }

    
    public void listarEmergenciasAtivas(){
        System.out.println("--- Emergências Atuais ---");
        for (Veiculo v : veiculosEmEmergencia) {
            System.out.println("Identificador: " + v.getIdentificador());
            System.out.println("Tipo de indentificador: " +v.getTipoIdentificador());
        }
    }
}
