import java.util.ArrayList;
import java.util.List;
import java.util.Scanner;

// 1. A classe agora herda de Usuario
public class UsuarioVeiculo extends Usuario {

    // 2. Construtor que repassa os dados para a classe pai (Usuario)
    public UsuarioVeiculo(String login, String senha, String nome) {
        super(login, senha, nome);
    }

    // 3. A lógica do seu método Veiculo() agora vive dentro do acessarSistema()
    @Override
    public void acessarSistema() {
        List<Veiculo> frota = new ArrayList<>();
        Scanner scanner = new Scanner(System.in);
        String continuar;

        System.out.println("\n==================================");
        System.out.println("Bem-vindo(a), " + super.getNome() + "!");
        System.out.println("---- Módulo de Cadastro de Veículos ----");

        do {
            System.out.println("Digite o identificador (Placa/Chassi):");
            String idInformado = scanner.nextLine();
            
            System.out.println("Digite o tipo de identificador:");
            String tipoIdInformado = scanner.nextLine();

            Localizacao locInicial = new Localizacao(-23.55, -46.63, 0.0, java.time.Instant.now());

            Veiculo v = new Veiculo(idInformado, tipoIdInformado, locInicial);
            frota.add(v);

            System.out.println("Deseja cadastrar outro veículo? (S/N)");
            continuar = scanner.nextLine();

        } while (continuar.equalsIgnoreCase("S"));
        
        System.out.println("\nResumo da Frota:");
        for (Veiculo v : frota) {
            System.out.println("ID: " + v.getId() + " | Identificador: " + v.getIdentificador() + " | Mapa: " + v.getLocalizacao().toGoogleMapsUrl());
        }
        
        // scanner.close(); -> REMOVIDO para não bloquear o System.in do menu principal do Login.
        System.out.println("Voltando ao menu principal...\n");
    }
}
