import java.util.ArrayList;
import java.util.List;
import java.util.Scanner;
import java.sql.Connection;


public class Sensor {
    private static int idSensor = 0;
    private int id;
    private String categoria;
    private String nome;
    private String undMedida;
    private String tipoDado;
    private double valorAtual = 0.0;
    private double limiteMaximo;

    Sensor(String categoria, String nome, String tipoDado, String undMedida) {
        this.setId();
        this.setCategoria(categoria);
        this.setNome(nome);
        this.setTipoDado(tipoDado);
        this.setUndMedida(undMedida);
        this.setValor(0);
        System.out.println("Sensor criado - id = " + this.getId());
    }

    public void setValor(double valor) {
        // Uso de .equals() para comparar Strings em Java
        if (this.tipoDado.equals("1/0") && (valor == 1 || valor == 0)) {
            this.valorAtual = valor;
        } else if (!this.tipoDado.equals("1/0")) {
            this.valorAtual = valor;
        } else {
            System.out.println("Nada feito. É esperado valor tipo: " + this.tipoDado);
        }
    }

    
    // Getters e Setters
    public void setId() {
        this.id = idSensor;
        idSensor++;
    }

    public void setCategoria(String categoria) {
        this.categoria = categoria;
    }
    
    public void setNome(String nome) { 
        this.nome = nome; 
    }
    
    public void setUndMedida(String undMedida) { 
        this.undMedida = undMedida; 
    }
    
    public void setTipoDado(String tipoDado) { 
        this.tipoDado = tipoDado; 
    }
    
     public void setLimiteMaximo(double limiteMaximo) { 
        this.limiteMaximo = limiteMaximo; 
    }
    
    public void setValorAtual(double valorAtual){
        this.valorAtual = valorAtual;
    }
    
    public int getId() { 
        return this.id; 
    }
    
    public String getNome() { 
        return this.nome;
    }
    
    public String getTipoDado() { 
        return this.tipoDado;
    }
    
    public double getValor() { 
        return this.valorAtual; 
    }
    
    public String getUndMedida(){
        return undMedida;
    }
    
    public double getLimiteMaximo() { 
        return this.limiteMaximo; 
    }
    
    public static void main(String[] args) {
    Scanner leitor = new Scanner(System.in);
    List<Veiculo> frota = new ArrayList<>();
    String continuarVeiculo;

    System.out.println("---- Iniciando o programa ----");

    do {
        System.out.println("\n--- Cadastro de Veículo ---");
        System.out.print("Digite o identificador do veículo (ex: ABC-1234): ");
        String identificador = leitor.nextLine();

        System.out.print("Digite o tipo de identificador (ex: Placa): ");
        String tipoIdentificador = leitor.nextLine();
        
        Localizacao locAtual = new Localizacao(-1.0, -21.34, 0.0, java.time.Instant.now());  

        // (identificador, tipoIdentificador, latitude, longitude)
        Veiculo v = new Veiculo(identificador, tipoIdentificador, locAtual);

        String continuarSensor;
        do {
            System.out.println("\n--- Adicionando Sensor ao Veículo " + identificador + " ---");
            System.out.print("Categoria (Ex: Motor): ");
            String cat = leitor.nextLine();
            
            System.out.print("Nome do Sensor (Ex: Temperatura): ");
            String nomeS = leitor.nextLine();
            
            System.out.print("Tipo de dado (Ex: 1/0 ou Float): ");
            String tipoD = leitor.nextLine();
            
            System.out.print("Unidade de medida: ");
            String und = leitor.nextLine();
            
             System.out.print("Limite Máximo: ");
            double limiteMaximo = leitor.nextDouble();

            // Cria o sensor e adiciona ao veículo
            Sensor s = new Sensor(cat, nomeS, tipoD, und);
            v.setSensor(s);

            System.out.print("Deseja cadastrar outro SENSOR para este veículo? (S/N): ");
            continuarSensor = leitor.nextLine();
        } while (continuarSensor.equalsIgnoreCase("S"));

        // Adiciona o veículo completo à lista
        frota.add(v);

        System.out.print("\nDeseja cadastrar outro VEÍCULO na frota? (S/N): ");
        continuarVeiculo = leitor.nextLine();

    } while (continuarVeiculo.equalsIgnoreCase("S"));

    // Exibição final
    System.out.println("\n---- Relatório de Frota Finalizada ----");
    for (Veiculo veic : frota) {
        veic.exibirStatusSensores();
        System.out.println("---------------------------------------");
    }
    
    leitor.close();
}
}
