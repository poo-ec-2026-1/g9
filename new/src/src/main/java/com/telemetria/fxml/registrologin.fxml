<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="504.0" prefWidth="691.0"
            xmlns="http://javafx.com/javafx/23.0.2"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="RegistroLoginController">

   <children>

      <ImageView fitHeight="603.0" fitWidth="858.0" layoutX="-124.0" layoutY="-57.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@imagens/cover-1777501769696-ahs3jw.jpg" />
         </image>
      </ImageView>

      <TextField fx:id="nomeCadastro"
                 layoutX="251.0"
                 layoutY="74.0"
                 prefHeight="52.0"
                 prefWidth="189.0"
                 promptText="Nome Completo" />

      <TextField fx:id="emailCadastro"
                 layoutX="248.0"
                 layoutY="168.0"
                 prefHeight="52.0"
                 prefWidth="197.0"
                 promptText="E-mail (será seu login)" />

      <TextField fx:id="senhaCadastro"
                 layoutX="248.0"
                 layoutY="262.0"
                 prefHeight="45.0"
                 prefWidth="197.0"
                 promptText="Senha" />

      <Button fx:id="botaoRegistro"
              layoutX="289.0"
              layoutY="350.0"
              mnemonicParsing="false"
              onAction="#registrar"
              prefHeight="45.0"
              prefWidth="114.0"
              text="Registrar" />

   </children>

</AnchorPane>
